# Production environment template for the EC2 host (MOB-3).
#
# Copy to /opt/skillomat/.env on the host, fill in the <...> placeholders, and
# `chmod 600` it. docker-compose.prod.yml reads these via variable substitution.
# NEVER commit the filled-in file — only this template is tracked.

APP_NAME=Skillomat
APP_ENV=production
# Generate ONCE during setup and pin it here; do not regenerate on deploy:
#   docker compose -f docker-compose.prod.yml run --rm backend php artisan key:generate --show
APP_KEY=<base64-app-key>
APP_DEBUG=false

# The public CloudFront URL (no custom domain yet). Used for password-reset email
# links and the Google OAuth return URL. Fill in once the distribution exists.
APP_URL=https://<distribution-id>.cloudfront.net
APP_FRONTEND_URL=https://<distribution-id>.cloudfront.net

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=skillomat
DB_USERNAME=skillomat
DB_PASSWORD=<strong-db-password>
# Used by mysql + the healthcheck in docker-compose.prod.yml.
DB_ROOT_PASSWORD=<strong-db-root-password>

SESSION_DRIVER=file
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync
CACHE_STORE=file
FILESYSTEM_DISK=local

# Email (MOB-7): production transactional mail goes through AWS SES.
# Keep this on 'log' until SES is provisioned, then flip to 'ses' (see
# documentation/kb/OPERATIONS.md → "Email (SES)"). MAIL_FROM_ADDRESS must be an SES
# verified identity. AWS_DEFAULT_REGION is the SES region.
MAIL_MAILER=log
MAIL_FROM_ADDRESS=<verified-sender@your-domain>
MAIL_FROM_NAME=Skillomat
# Provision SES in the same region as the EC2 host (eu-central-1); identities are
# per-region, so the verified sender must live in whatever region this points at.
AWS_DEFAULT_REGION=eu-central-1
# Preferred: leave these unset and attach an SES-send policy to the EC2 instance role
# (the SDK reads instance-metadata credentials). Fallback: a dedicated SES IAM user.
# AWS_ACCESS_KEY_ID=<ses-iam-user-key>
# AWS_SECRET_ACCESS_KEY=<ses-iam-user-secret>

# Google OAuth (Socialite). Create an OAuth 2.0 client at
# https://console.cloud.google.com/apis/credentials and set its authorized
# redirect URI to GOOGLE_REDIRECT_URI below — it must match exactly, or Google
# rejects the sign-in with a redirect_uri error. Leave all three blank to
# disable Google sign-in.
GOOGLE_CLIENT_ID=<google-client-id>
GOOGLE_CLIENT_SECRET=<google-client-secret>
GOOGLE_REDIRECT_URI=https://<distribution-id>.cloudfront.net/api/auth/google/callback
